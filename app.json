{
  "expo": {
    "name": "Podink",
    "slug": "podink",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.podink.app",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.podink.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#EDE8E1"
      }
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
